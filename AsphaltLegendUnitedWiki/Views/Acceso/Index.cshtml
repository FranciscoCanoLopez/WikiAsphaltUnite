@model Usuario
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>UNITE - Acceso</title>
    <link rel="stylesheet" href="~/css/estilos.css">
    </head>
    <body>
        <main class="unite-container">
            <div class="unite-banner">
                <img src="~/images/fondo_asphalt.jpg" alt="Asphalt Unite Banner">
                </div>

                <div class="unite-form-side">
                    <h1 class="unite-title">INICIA SESION</h1>
                    <hr class="unite-divider">

                    <form asp-action="Login" method="post">
                        <div class="unite-group">
                            <label>USUARIO</label>
                            <input type="text" name="correo" class="unite-input" required autocomplete="off">
                        </div>

                        <div class="unite-group" style="margin-top:20px;">
                            <label>CONTRASEÑA</label>
                            <input type="password" name="contrasena" class="unite-input" required>
                        </div>

                        <div style="text-align: center; margin-top: 30px;">
                            <button type="submit" class="unite-btn">ENTRAR</button>
                        </div>
                    </form>

                    <hr class="unite-divider">
            
                    <h1 class="unite-title" style="font-size: 1.8rem;">CREAR CUENTA</h1>
                    <div style="text-align: center;">
                        <a href="@Url.Action("Registrarse", "Acceso")" class="unite-btn" style="text-decoration:none; display:inline-block;">CREAR</a>
                    </div>
                </div>
            </main>
        </body>
    </html>